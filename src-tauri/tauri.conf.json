{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SilentKeys",
  "version": "0.3.0",
  "identifier": "com.kti.silent-keys",
  "build": {
    "beforeDevCommand": "trunk serve",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "trunk build --release",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SilentKeys",
        "width": 1024,
        "height": 1024
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "img-src": "'self'",
        "style-src": "'self'",
        "script-src": "'self' 'wasm-unsafe-eval'"
      },
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDOTAyOTVBMkY1RjJGQzIKUldUQ0wxOHZXaW1RZkxNSWJRSFgxRFpaYjJ2M1FubG9zem5yVE9uNzhseXVZRWZlb0o4YUJkSE4K",
      "endpoints": [
        "https://github.com/gptguy/silentkeys/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
